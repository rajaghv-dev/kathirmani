  "panels": [
    {
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 5
      },
      "options": {
        "mode": "markdown",
        "content": "### 13 — Model Latency\nLatency distribution per model/runtime. p50/p95/p99 of `model_latency_ms` (end-to-end) and `model_ttft_ms` (time-to-first-token for generative models). p95 is the SLO lens; watch for runtime-dependent tails (vLLM vs Ollama vs TensorRT-LLM). Metrics: `model_latency_ms`, `model_ttft_ms`."
      },
      "id": 1
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (ms)",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(model_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(model_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(model_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "id": 2
    },
    {
      "type": "timeseries",
      "title": "Latency p95 by model/runtime",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(model_latency_ms_bucket[5m])) by (le, model_id, runtime))",
          "legendFormat": "{{model_id}}/{{runtime}}"
        }
      ],
      "id": 3
    },
    {
      "type": "timeseries",
      "title": "TTFT p95 by model (generative)",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(model_ttft_ms_bucket[5m])) by (le, model_id))",
          "legendFormat": "{{model_id}}"
        }
      ],
      "id": 4
    }
  ]
