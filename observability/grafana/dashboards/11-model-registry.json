{
  "title": "11 — Model Registry",
  "uid": "kathir-11-model-registry",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "kathir",
    "model-benchmarks"
  ],
  "panels": [
    {
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 5
      },
      "options": {
        "mode": "markdown",
        "content": "### 11 — Model Registry\nWhich models/runtimes/profiles are live and serving traffic (spec/11 plugin layer). Each series is a `(model_id, task, runtime, profile)` tuple from `model_requests_total`. The NVIDIA-only policy means production defaults are Nemotron/Cosmos; `research_qwen_baseline` shows as a comparison-only profile. Metrics: `model_*`."
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Active model series",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(count(model_requests_total) by (model_id))",
          "legendFormat": "Active model series"
        }
      ],
      "id": 2
    },
    {
      "type": "stat",
      "title": "Active runtimes",
      "gridPos": {
        "x": 6,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "purple"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(count(model_requests_total) by (runtime))",
          "legendFormat": "Active runtimes"
        }
      ],
      "id": 3
    },
    {
      "type": "stat",
      "title": "Active profiles",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(count(model_requests_total) by (profile))",
          "legendFormat": "Active profiles"
        }
      ],
      "id": 4
    },
    {
      "type": "table",
      "title": "Registered models (model / task / runtime / profile)",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "sum(model_requests_total) by (model_id, task, runtime, profile)",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ],
      "id": 5
    },
    {
      "type": "bargauge",
      "title": "Requests by model",
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {
            "mode": "continuous-BlYlRd"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(model_requests_total) by (model_id)",
          "legendFormat": "{{model_id}}"
        }
      ],
      "id": 6
    }
  ]
}
