{
  "title": "10 — TCO",
  "uid": "kathir-10-tco",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "kathir",
    "platform"
  ],
  "panels": [
    {
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 5
      },
      "options": {
        "mode": "markdown",
        "content": "### 10 — TCO\nCost / efficiency of the running platform. Anti-goal #4 (spec/10): measure video-sec/sec/GPU and clips/min/GPU, not tokens/sec alone. Here: video seconds processed, clips/min/GPU throughput, and request volume as a cost proxy. Money deltas across GPU profiles live in dashboard 15. Metrics: `model_*`, `marlin_*`."
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Video seconds processed",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(model_video_seconds_processed_total)",
          "legendFormat": "Video seconds processed"
        }
      ],
      "id": 2
    },
    {
      "type": "stat",
      "title": "Clips processed",
      "gridPos": {
        "x": 6,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(model_clips_processed_total)",
          "legendFormat": "Clips processed"
        }
      ],
      "id": 3
    },
    {
      "type": "stat",
      "title": "Total requests",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "purple"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(model_requests_total)",
          "legendFormat": "Total requests"
        }
      ],
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "Video-sec processed /s (throughput)",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(model_video_seconds_processed_total[5m])) by (profile)",
          "legendFormat": "{{profile}}"
        }
      ],
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "Clips/min by profile",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "60 * sum(rate(model_clips_processed_total[5m])) by (profile)",
          "legendFormat": "{{profile}}"
        }
      ],
      "id": 6
    }
  ]
}
