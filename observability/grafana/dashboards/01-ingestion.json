{
  "title": "01 — Ingestion Health",
  "uid": "kathir-01-ingestion",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "kathir",
    "platform"
  ],
  "panels": [
    {
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 5
      },
      "options": {
        "mode": "markdown",
        "content": "### 01 — Ingestion Health\nIs footage flowing? **Segments** = durable 10-sec clips written per camera; **windows** = 5-sec AI windows derived from them; **frames decoded** = decode throughput. Rising `ingest_errors_total` or a flat segment rate means ingestion is stalling. Metrics: `ingest_*` (ingestion/metrics.py, scraped on :8901)."
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Segments written (total)",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(ingest_segments_written_total)",
          "legendFormat": "Segments written (total)"
        }
      ],
      "id": 2
    },
    {
      "type": "stat",
      "title": "AI windows created",
      "gridPos": {
        "x": 6,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(ingest_windows_created_total)",
          "legendFormat": "AI windows created"
        }
      ],
      "id": 3
    },
    {
      "type": "stat",
      "title": "Frames decoded",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "purple"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(ingest_frames_decoded_total)",
          "legendFormat": "Frames decoded"
        }
      ],
      "id": 4
    },
    {
      "type": "stat",
      "title": "Ingestion errors",
      "gridPos": {
        "x": 18,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(ingest_errors_total)",
          "legendFormat": "Ingestion errors"
        }
      ],
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "Segments written /s (per camera)",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "rate(ingest_segments_written_total[5m])",
          "legendFormat": "{{store_id}}/{{camera_id}}"
        }
      ],
      "id": 6
    },
    {
      "type": "timeseries",
      "title": "Windows created /s (per camera)",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "rate(ingest_windows_created_total[5m])",
          "legendFormat": "{{store_id}}/{{camera_id}}"
        }
      ],
      "id": 7
    },
    {
      "type": "timeseries",
      "title": "Segment write latency p95 (s)",
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ingest_segment_write_latency_seconds_bucket[5m])) by (le, camera_id))",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "id": 8
    },
    {
      "type": "timeseries",
      "title": "Ingestion errors /s by stage",
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(ingest_errors_total[5m])) by (stage)",
          "legendFormat": "{{stage}}"
        }
      ],
      "id": 9
    }
  ]
}
