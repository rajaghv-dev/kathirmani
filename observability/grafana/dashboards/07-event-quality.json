{
  "title": "07 — Event Quality",
  "uid": "kathir-07-event-quality",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "kathir",
    "platform"
  ],
  "panels": [
    {
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 5
      },
      "options": {
        "mode": "markdown",
        "content": "### 07 — Event Quality\nAre the model's events worth acting on? Precision/recall on the golden dataset (`model_event_precision` / `model_event_recall`, labelled by `dataset`) and the golden-regression score guard against drift. These are gauges set by the benchmark harness, not live per-request. Metrics: `model_event_*`, `model_golden_regression_score`."
      },
      "id": 1
    },
    {
      "type": "gauge",
      "title": "Event precision (latest)",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 0.6,
                "color": "yellow"
              },
              {
                "value": 0.85,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max(model_event_precision)",
          "legendFormat": "Event precision (latest)"
        }
      ],
      "id": 2
    },
    {
      "type": "gauge",
      "title": "Event recall (latest)",
      "gridPos": {
        "x": 6,
        "y": 5,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 0.6,
                "color": "yellow"
              },
              {
                "value": 0.85,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max(model_event_recall)",
          "legendFormat": "Event recall (latest)"
        }
      ],
      "id": 3
    },
    {
      "type": "gauge",
      "title": "Golden regression score",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 0.6,
                "color": "yellow"
              },
              {
                "value": 0.85,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max(model_golden_regression_score)",
          "legendFormat": "Golden regression score"
        }
      ],
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "Precision by model/dataset",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "model_event_precision",
          "legendFormat": "{{model_id}}/{{dataset}}"
        }
      ],
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "Recall by model/dataset",
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "model_event_recall",
          "legendFormat": "{{model_id}}/{{dataset}}"
        }
      ],
      "id": 6
    },
    {
      "type": "table",
      "title": "Quality snapshot (precision / recall / golden)",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "model_event_precision",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "model_event_recall",
          "legendFormat": "",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "model_golden_regression_score",
          "legendFormat": "",
          "instant": true,
          "refId": "C"
        }
      ],
      "id": 7
    }
  ]
}
