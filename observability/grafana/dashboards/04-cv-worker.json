    {
      "type": "timeseries",
      "title": "Detection latency p95 (ms) by model",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(model_latency_ms_bucket{task=~\"detection|tracking\"}[5m])) by (le, model_id))",
          "legendFormat": "{{model_id}}"
        }
      ],
      "id": 6
    },
