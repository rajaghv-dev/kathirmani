{
  "title": "04 — CV Worker",
  "uid": "kathir-04-cv-worker",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "kathir",
    "platform"
  ],
  "panels": [
    {
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 5
      },
      "options": {
        "mode": "markdown",
        "content": "### 04 — CV Worker\nDetection/tracking workers (DetectionPlugin / TrackingPlugin, spec/11). Filtered to `task=~\"detection|tracking\"`. Throughput = clips/frames processed; latency p95 from `model_latency_ms`; request success vs error split. A failed event traces back to a worker here (Phase-3 done-when). Metrics: `model_*`."
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Clips processed",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(model_clips_processed_total{task=~\"detection|tracking\"})",
          "legendFormat": "Clips processed"
        }
      ],
      "id": 2
    },
    {
      "type": "stat",
      "title": "Frames processed",
      "gridPos": {
        "x": 6,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(model_frames_processed_total{task=~\"detection|tracking\"})",
          "legendFormat": "Frames processed"
        }
      ],
      "id": 3
    },
    {
      "type": "stat",
      "title": "Requests (ok)",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(model_requests_total{task=~\"detection|tracking\",status=\"ok\"})",
          "legendFormat": "Requests (ok)"
