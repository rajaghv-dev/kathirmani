{
  "title": "02 — Camera Health",
  "uid": "kathir-02-camera",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "kathir",
    "platform"
  ],
  "panels": [
    {
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 5
      },
      "options": {
        "mode": "markdown",
        "content": "### 02 — Camera Health\nPer-camera signal quality. `ingest_rtsp_connected` (1=open) shows the feed is live; `ingest_camera_health_score` is the 0..1 composite. Black-frame / blur / freeze scores (1=bad) and observed fps (`ingest_camera_fps_actual`) localise *why* a camera is degraded. Metrics: `ingest_*`."
      },
      "id": 1
    },
    {
      "type": "bargauge",
      "title": "Camera health score (0..1)",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "color": {
            "mode": "continuous-BlYlRd"
          }
        }
      },
      "targets": [
        {
          "expr": "ingest_camera_health_score",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "id": 2
    },
    {
      "type": "timeseries",
      "title": "RTSP connected (1=open)",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "bars"
          }
        }
      },
      "targets": [
        {
          "expr": "ingest_rtsp_connected",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "id": 3
    },
    {
      "type": "timeseries",
      "title": "Observed fps",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "ingest_camera_fps_actual",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "Black-frame score (1=dark)",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "ingest_camera_black_frame_score",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "Blur score (1=blurry)",
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "ingest_camera_blur_score",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "id": 6
    },
    {
      "type": "timeseries",
      "title": "Freeze score (1=frozen)",
      "gridPos": {
        "x": 0,
        "y": 45,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "ingest_camera_freeze_score",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "id": 7
    }
  ]
}
