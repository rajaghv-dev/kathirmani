{
  "title": "17 — Model Failure / Drift",
  "uid": "kathir-17-model-failure-drift",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "kathir",
    "model-benchmarks"
  ],
  "panels": [
    {
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 5
      },
      "options": {
        "mode": "markdown",
        "content": "### 17 — Model Failure / Drift\nReliability + drift early-warning. Error rate by type (`model_errors_total`), the non-ok request ratio, and JSON-parse failures flag operational failure; a falling `model_golden_regression_score` over time flags quality drift that should trigger a rollback (Phase 12). Metrics: `model_errors_total`, `model_requests_total`, `model_json_parse_total`, `model_golden_regression_score`."
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Total errors",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(model_errors_total)",
          "legendFormat": "Total errors"
        }
      ],
      "id": 2
    },
    {
      "type": "stat",
      "title": "Parse failures",
      "gridPos": {
        "x": 6,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "orange"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(model_json_parse_total{result=\"fail\"})",
          "legendFormat": "Parse failures"
        }
      ],
      "id": 3
    },
    {
      "type": "gauge",
      "title": "Min golden score (drift floor)",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 0.6,
                "color": "yellow"
              },
              {
                "value": 0.85,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "min(model_golden_regression_score)",
          "legendFormat": "Min golden score (drift floor)"
        }
      ],
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "Error ratio by model",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(model_requests_total{status!=\"ok\"}[5m])) by (model_id) / sum(rate(model_requests_total[5m])) by (model_id)",
          "legendFormat": "{{model_id}}"
        }
      ],
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "Errors /s by type",
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(model_errors_total[5m])) by (error_type)",
          "legendFormat": "{{error_type}}"
        }
      ],
      "id": 6
    },
    {
      "type": "timeseries",
      "title": "Golden regression score over time (drift)",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "model_golden_regression_score",
          "legendFormat": "{{model_id}}/{{dataset}}"
        }
      ],
      "id": 7
    }
  ]
}
