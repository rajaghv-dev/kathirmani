{
  "title": "08 — Incidents",
  "uid": "kathir-08-incidents",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "kathir",
    "platform"
  ],
  "panels": [
    {
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 5
      },
      "options": {
        "mode": "markdown",
        "content": "### 08 — Incidents\nLoss-prevention incidents = suspicious events the rule engine raised and the VLM confirmed. Approximated here from VLM verdicts (`model_verdict_total{verdict=...}`) until the dedicated incident metric lands in the rule engine (Phase 5). An incident is a *flag to review*, never a confirmed theft (spec/08). Metrics: `model_verdict_total`."
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Suspicious verdicts",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(model_verdict_total{verdict=~\"suspicious|confirmed\"})",
          "legendFormat": "Suspicious verdicts"
        }
      ],
      "id": 2
    },
    {
      "type": "stat",
      "title": "Cleared verdicts",
      "gridPos": {
        "x": 6,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(model_verdict_total{verdict=~\"clear|benign\"})",
          "legendFormat": "Cleared verdicts"
        }
      ],
      "id": 3
    },
    {
      "type": "stat",
      "title": "Total verdicts",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(model_verdict_total)",
          "legendFormat": "Total verdicts"
        }
      ],
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "Verdicts /s by class",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(model_verdict_total[15m])) by (verdict)",
          "legendFormat": "{{verdict}}"
        }
      ],
      "id": 5
    },
    {
      "type": "bargauge",
      "title": "Verdict distribution",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {
            "mode": "continuous-BlYlRd"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(model_verdict_total) by (verdict)",
          "legendFormat": "{{verdict}}"
        }
      ],
      "id": 6
    }
  ]
}
