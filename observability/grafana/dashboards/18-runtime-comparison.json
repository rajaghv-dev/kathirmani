{
  "title": "18 — Runtime Comparison",
  "uid": "kathir-18-runtime-comparison",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "kathir",
    "model-benchmarks"
  ],
  "panels": [
    {
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 5
      },
      "options": {
        "mode": "markdown",
        "content": "### 18 — Runtime Comparison\nThe Phase-13 NVIDIA bake-off lens: same model, different `runtime` (Ollama / llama.cpp / vLLM / Triton / NIM / TensorRT-LLM). Compares latency p95, throughput (clips/min, tok/s) and error rate **by runtime** so a config-only profile swap shows its Grafana deltas (spec/10 Phase 13 done-when). Metrics: `model_*` grouped by `runtime`."
      },
      "id": 1
    },
    {
      "type": "bargauge",
      "title": "Requests by runtime",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {
            "mode": "continuous-BlYlRd"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(model_requests_total) by (runtime)",
          "legendFormat": "{{runtime}}"
        }
      ],
      "id": 2
    },
    {
      "type": "timeseries",
      "title": "Latency p95 by runtime (ms)",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(model_latency_ms_bucket[5m])) by (le, runtime))",
          "legendFormat": "{{runtime}}"
        }
      ],
      "id": 3
    },
    {
      "type": "timeseries",
      "title": "Clips/min by runtime",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "60 * sum(rate(model_clips_processed_total[5m])) by (runtime)",
          "legendFormat": "{{runtime}}"
        }
      ],
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "Decode tok/s by runtime",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "avg(model_tokens_per_second) by (runtime)",
          "legendFormat": "{{runtime}}"
        }
      ],
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "Error ratio by runtime",
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "drawStyle": "line"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(model_requests_total{status!=\"ok\"}[5m])) by (runtime) / sum(rate(model_requests_total[5m])) by (runtime)",
          "legendFormat": "{{runtime}}"
        }
      ],
      "id": 6
    }
  ]
}
