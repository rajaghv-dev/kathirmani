# Copy to .env and fill. NEVER commit .env (secrets — spec/10 Security).
# .env is gitignored; only this example is tracked.

# ---- Model profile (config-only model swap; spec/11) ----
MODEL_PROFILE=nvidia_gb10_retail_balanced

# ---- HuggingFace (free NVIDIA models) ----
# Token already stored at ~/.cache/huggingface/token on this box; set here only to override.
# HF_TOKEN=

# ---- NGC (only needed for DeepStream / NIM / TAO — optional, not on this box yet) ----
# NGC_API_KEY=

# ---- Design-asset image generation (design/ai_images.py — design-time only, NOT inference) ----
# Google "Nano Banana" (Gemini 2.5 Flash Image); GOOGLE_API_KEY also accepted.
# GEMINI_API_KEY=
# OpenAI gpt-image-1.
# OPENAI_API_KEY=

# ---- Postgres ----
POSTGRES_USER=kathir
POSTGRES_PASSWORD=change_me
POSTGRES_DB=kathirmani
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- MinIO (object store) ----
MINIO_ROOT_USER=kathir
MINIO_ROOT_PASSWORD=change_me
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- Observability ports ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
LOKI_PORT=3100
NETDATA_PORT=19999
DCGM_PORT=9400
OLLAMA_PORT=11434

# ---- Camera RTSP URLs (Phase 1 live mode; file mode uses configs/cameras.yaml source_file) ----
RTSP_BILL_COUNTER=
RTSP_CENTER=
RTSP_LEFT_AISLE=
RTSP_ENTRY_EXIT=
RTSP_RIGHT_AISLE=
