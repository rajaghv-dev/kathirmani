{
  "title": "Marlin-2B \u2014 Model & Runtime",
  "uid": "marlin-model-runtime",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": [
    "marlin",
    "dgx",
    "runtime"
  ],
  "panels": [
    {
      "id": 22,
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "### Model & Runtime \u2014 \"is the box healthy?\"\nHardware/infra health of the DGX Spark **GB10** during a run: power (W), compute utilization %, temperature, unified memory, and CPU/RAM (from **Netdata**). Use it to confirm the box is actually working and isn't thermal- or memory-constrained. The Videos/Events stats are just a sanity check that a run landed."
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "DGX Power (W)",
      "description": "DGX Spark GB10 \u2014 Grace Blackwell, 119GB unified memory",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 60,
                "color": "yellow"
              },
              {
                "value": 100,
                "color": "red"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_dgx_power_watts",
          "legendFormat": "Power W"
        }
      ]
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Compute Util %",
      "gridPos": {
        "x": 4,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 90,
                "color": "red"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_dgx_compute_utilization_percent",
          "legendFormat": "Compute Util %"
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "System Temp \u00b0C",
      "gridPos": {
        "x": 8,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "celsius",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 85,
                "color": "red"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_dgx_temperature_celsius",
          "legendFormat": "Temp \u00b0C"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Videos Processed",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_videos_processed_total",
          "legendFormat": "Processed"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Events",
      "gridPos": {
        "x": 15,
        "y": 4,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_total_events",
          "legendFormat": "Events"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Events \u2014 Bill Counter",
      "gridPos": {
        "x": 18,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "purple"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_events_detected_total{video=\"Kathirmani Bill Counter\"}",
          "legendFormat": "Bill Counter events"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Unified Memory Over Time",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity"
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_dgx_unified_mem_used_gb",
          "legendFormat": "Unified Mem Used (GB)"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Compute Utilization & Temperature",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Compute Util %"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "System Temp \u00b0C"
            },
            "properties": [
              {
                "id": "unit",
                "value": "celsius"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "marlin_dgx_compute_utilization_percent",
          "legendFormat": "Compute Util %"
        },
        {
          "expr": "marlin_dgx_temperature_celsius",
          "legendFormat": "System Temp \u00b0C"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "System CPU \u2014 Netdata",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "netdata-prom"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "netdata_system_cpu_percentage_average{dimension=~\"user|system\"}",
          "legendFormat": "CPU {{dimension}}"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "System RAM \u2014 Netdata",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "netdata-prom"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "netdata_system_ram_MiB_average{dimension=~\"used|cached\"}",
          "legendFormat": "RAM {{dimension}}"
        }
      ]
    }
  ]
}