{
  "title": "Marlin-2B — Model & Runtime",
  "uid": "marlin-model-runtime",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["marlin", "gpu", "runtime"],
  "panels": [
    {
      "id": 1, "type": "stat", "title": "GPU Power (W)",
      "description": "GB10 uses unified memory — power draw is the key GPU load indicator",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "watt", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{"value":null,"color":"green"},{"value":60,"color":"yellow"},{"value":100,"color":"red"}] } } },
      "targets": [{ "expr": "marlin_gpu_power_watts", "legendFormat": "Power W" }]
    },
    {
      "id": 2, "type": "gauge", "title": "GPU Utilization %",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{"value":null,"color":"green"},{"value":70,"color":"yellow"},{"value":90,"color":"red"}] } } },
      "targets": [{ "expr": "marlin_gpu_utilization_percent", "legendFormat": "GPU Util %" }]
    },
    {
      "id": 3, "type": "gauge", "title": "GPU Temperature °C",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "celsius", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{"value":null,"color":"green"},{"value":70,"color":"yellow"},{"value":85,"color":"red"}] } } },
      "targets": [{ "expr": "marlin_gpu_temperature_celsius", "legendFormat": "Temp °C" }]
    },
    {
      "id": 4, "type": "stat", "title": "Videos Processed",
      "gridPos": { "x": 12, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{"value":null,"color":"blue"}] } } },
      "targets": [{ "expr": "marlin_videos_processed_total", "legendFormat": "Processed" }]
    },
    {
      "id": 5, "type": "stat", "title": "Total Events",
      "gridPos": { "x": 15, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{"value":null,"color":"green"}] } } },
      "targets": [{ "expr": "marlin_total_events", "legendFormat": "Events" }]
    },
    {
      "id": 6, "type": "stat", "title": "Events — Bill Counter",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{"value":null,"color":"purple"}] } } },
      "targets": [{ "expr": "marlin_events_detected_total{video=\"Kathirmani Bill Counter\"}", "legendFormat": "Bill Counter events" }]
    },
    {
      "id": 10, "type": "timeseries", "title": "GPU Memory Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity" } } },
      "targets": [{ "expr": "marlin_gpu_memory_used_mb", "legendFormat": "GPU Memory (MB)" }]
    },
    {
      "id": 11, "type": "timeseries", "title": "GPU Utilization & Temperature",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "GPU Util %" }, "properties": [{"id":"unit","value":"percent"},{"id":"color","value":{"fixedColor":"green","mode":"fixed"}}] },
          { "matcher": { "id": "byName", "options": "GPU Temp °C" }, "properties": [{"id":"unit","value":"celsius"},{"id":"color","value":{"fixedColor":"orange","mode":"fixed"}}] }
        ]
      },
      "targets": [
        { "expr": "marlin_gpu_utilization_percent", "legendFormat": "GPU Util %" },
        { "expr": "marlin_gpu_temperature_celsius", "legendFormat": "GPU Temp °C" }
      ]
    },
    {
      "id": 20, "type": "timeseries", "title": "System CPU — Netdata",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "netdata-prom" },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "lineWidth": 1, "fillOpacity": 10 } } },
      "targets": [{ "expr": "netdata_system_cpu_percentage_average{dimension=~\"user|system\"}", "legendFormat": "CPU {{dimension}}" }]
    },
    {
      "id": 21, "type": "timeseries", "title": "System RAM — Netdata",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "netdata-prom" },
      "fieldConfig": { "defaults": { "unit": "decmbytes", "custom": { "lineWidth": 1, "fillOpacity": 10 } } },
      "targets": [{ "expr": "netdata_system_ram_MiB_average{dimension=~\"used|cached\"}", "legendFormat": "RAM {{dimension}}" }]
    }
  ]
}
