{
  "title": "Marlin \u2014 Model Performance & Usefulness",
  "uid": "marlin-model-perf",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
