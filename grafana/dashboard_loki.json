{
  "title": "Kathirmani \u2014 Inference Logs (Loki)",
  "uid": "marlin-loki",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "tags": [
    "marlin",
    "loki",
    "logs",
    "surveillance"
  ],
  "panels": [
    {
      "id": 32,
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "### Inference Logs (Loki) \u2014 \"the play-by-play\"\nRaw **log lines**, not metrics (source: Loki). Live feed of all inference logs, per-camera **captions** (the model's own description of what it saw), find **hits**, **queries not found** (coverage gaps), errors, and run start/complete markers. Come here when a number elsewhere looks wrong and you want the story behind it."
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Events Detected (this run)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 4,
        "h": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(marlin_events_detected_total)",
          "legendFormat": "Events"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Find Hits",
      "gridPos": {
        "x": 4,
        "y": 4,
        "w": 4,
        "h": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(marlin_find_parse_success == 1)",
          "legendFormat": "Hits"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Find Misses",
      "gridPos": {
        "x": 8,
        "y": 4,
        "w": 4,
        "h": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "yellow"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(marlin_find_parse_success == 0)",
          "legendFormat": "Misses"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cameras Processed",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 4,
        "h": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "purple"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_videos_processed_total",
          "legendFormat": "Cameras"
        }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "All Inference Logs \u2014 Live Feed",
      "description": "All events from the current inference run across all cameras. Filter by label in the top bar.",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-marlin"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{app=\"marlin\",store=\"kathirmani\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
