{
  "title": "Kathirmani \u2014 Camera Views",
  "uid": "marlin-cameras",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": [
    "marlin",
    "cameras",
    "surveillance",
    "kathirmani"
  ],
  "panels": [
    {
      "id": 504,
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "### Camera Views \u2014 \"what happened on each camera?\"\nOne row per camera (all 5). Each row: **events detected**, **find-span duration** per query, and **parse success %**. Use it to compare cameras \u2014 e.g. the entry door sees more events than a side aisle, or one camera's output formatting is failing."
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "Kathirmani Bill Counter",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 101,
      "type": "stat",
      "title": "Events Detected \u2014 Bill Counter",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_events_detected_total{video=\"Kathirmani Bill Counter\"}",
          "legendFormat": "Events"
        }
      ]
    },
    {
      "id": 102,
      "type": "bargauge",
      "title": "Find Span Duration per Query \u2014 Bill Counter",
      "gridPos": {
        "x": 6,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": {
            "mode": "continuous-BlYlRd"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_find_span_duration_seconds{video=\"Kathirmani Bill Counter\"}",
          "legendFormat": "{{query}}"
        }
      ]
    },
    {
      "id": 103,
      "type": "stat",
      "title": "Parse Success Rate \u2014 Bill Counter",
      "gridPos": {
        "x": 18,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 0.7,
                "color": "yellow"
              },
              {
                "value": 0.9,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg(marlin_find_parse_success{video=\"Kathirmani Bill Counter\"})",
          "legendFormat": "Parse OK"
        }
      ]
    },
