              },
              {
                "value": 0.7,
                "color": "yellow"
              },
              {
                "value": 0.9,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg(marlin_find_parse_success)",
          "legendFormat": "Parse OK"
        }
      ]
    },
