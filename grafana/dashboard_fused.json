      },
      "targets": [
        {
          "expr": "marlin_events_detected_total",
          "legendFormat": "{{video}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 41,
      "type": "stat",
      "title": "Overall Parse Success Rate (All Cameras)",
      "description": "Average parse success across all cameras and all find queries",
      "gridPos": {
        "x": 12,
        "y": 38,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
