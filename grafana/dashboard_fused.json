{
  "title": "Kathirmani \u2014 Store View (Fused)",
  "uid": "marlin-fused",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": [
    "marlin",
    "fused",
    "store",
    "kathirmani"
  ],
  "panels": [
    {
      "id": 43,
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "### Store View (Fused) \u2014 \"what happened in the store?\"\nCross-camera rollup. The 5 cameras watch the same area from different angles, so the same real event is seen several times. **Fusion** dedups them: `raw events` = before dedup, `unique events` = after. \"Best camera\" span = the tightest window for a query across all angles. Closest thing to a single store-wide truth."
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Unique Events After Dedup",
      "description": "Deduplicated event count across all cameras (fused truth)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_fused_unique_events",
          "legendFormat": "Unique Events"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Raw Events Before Dedup",
      "description": "Sum of all events across all cameras before deduplication",
      "gridPos": {
        "x": 6,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_fused_raw_events_total",
          "legendFormat": "Raw Events"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Videos Processed",
      "description": "Total cameras with inference results on disk",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              },
              {
                "value": 1,
                "color": "green"
              },
              {
                "value": 5,
                "color": "super-light-green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_videos_processed_total",
          "legendFormat": "Videos"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Find Queries Resolved",
      "description": "Total find queries that parsed successfully across all cameras",
      "gridPos": {
        "x": 18,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "purple"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(marlin_find_parse_success == 1)",
          "legendFormat": "Resolved"
        }
      ]
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Fused Find Spans \u2014 Best Camera Duration per Query",
      "description": "For each query, the longest span seen across all cameras (proxy for best-camera fused answer). Uses marlin_fused_find_span_* when available, falls back to max across cameras.",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": {
            "mode": "continuous-BlYlRd"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_fused_find_span_end_seconds - marlin_fused_find_span_start_seconds",
          "legendFormat": "{{query}} (fused)",
          "refId": "A"
        },
        {
          "expr": "max by (query) (marlin_find_span_duration_seconds)",
          "legendFormat": "{{query}} (best cam)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 20,
      "type": "table",
      "title": "All Find Results \u2014 All Cameras (Un-fused Comparison)",
      "description": "Span duration per video+query combination. Shows which camera detected each event longest \u2014 useful for understanding camera coverage.",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Duration (s)",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Duration (s)"
              },
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "video"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 240
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "query"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 280
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "marlin_find_span_duration_seconds",
          "legendFormat": "",
          "instant": true,
          "refId": "A",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "video",
                "query",
                "Value"
              ]
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "displayName": "Duration (s)",
                "desc": true
              }
            ]
          }
        }
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Events Detected Over Time \u2014 Per Camera",
      "description": "Tracks how many events each camera has detected. All cameras see the same store area from different angles.",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "marlin_events_detected_total",
          "legendFormat": "{{video}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 40,
      "type": "bargauge",
      "title": "Events Detected \u2014 All Cameras",
      "description": "Side-by-side event count for each camera. All cameras see the same Kathirmani store.",
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 12,
        "h": 6
      },
      "datasource": {
