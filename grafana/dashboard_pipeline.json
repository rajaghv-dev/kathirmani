{
  "title": "Marlin-2B \u2014 Application / Pipeline",
  "uid": "marlin-pipeline",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": [
    "marlin",
    "pipeline",
    "surveillance"
  ],
  "panels": [
    {
      "id": 31,
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "### Application / Pipeline \u2014 \"did the model do its job?\"\nPer-run **output quality** (example camera: Bill Counter). **Event** = something Marlin's caption mode noticed. **Find/span** = a query answered with a time window `[start,end]` in seconds; duration = `end\u2212start`. **Parse success %** = did the model's text come back in the expected format (formatting, not truth) \u2014 aim ~100%."
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Videos with Results",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "kathirmani_videos_processed_total",
          "legendFormat": "Videos"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Events Detected",
      "gridPos": {
        "x": 4,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "kathirmani_total_events",
          "legendFormat": "Events"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Find Queries Resolved",
      "gridPos": {
        "x": 8,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "purple"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(kathirmani_find_parse_success == 1)",
          "legendFormat": "Resolved"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Parse Success Rate",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 0.7,
                "color": "yellow"
              },
              {
                "value": 0.9,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg(kathirmani_find_parse_success)",
          "legendFormat": "Parse OK"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Bill Counter Events",
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "kathirmani_events_detected_total{video=\"Kathirmani Bill Counter\"}",
          "legendFormat": "Events"
        }
      ]
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "Find Results \u2014 Avg Span Duration (s)",
      "gridPos": {
        "x": 20,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": false
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 10,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg(kathirmani_find_span_duration_seconds)",
          "legendFormat": "Avg span"
        }
      ]
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Find Query \u2014 Span Duration per Event (Bill Counter)",
      "description": "How long each detected event lasts in the Bill Counter footage",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": {
            "mode": "continuous-BlYlRd"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "kathirmani_find_span_duration_seconds{video=\"Kathirmani Bill Counter\"}",
          "legendFormat": "{{query}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "table",
      "title": "Find Query Results \u2014 Bill Counter Camera",
      "description": "Start/end timestamps for each event queried by the model",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value #A"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Start (s)"
              },
              {
                "id": "unit",
                "value": "s"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #B"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "End (s)"
              },
              {
                "id": "unit",
                "value": "s"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #C"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Duration (s)"
              },
              {
                "id": "unit",
                "value": "s"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #D"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Parsed OK"
              },
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "kathirmani_find_span_start_seconds{video=\"Kathirmani Bill Counter\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "kathirmani_find_span_end_seconds{video=\"Kathirmani Bill Counter\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "kathirmani_find_span_duration_seconds{video=\"Kathirmani Bill Counter\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "kathirmani_find_parse_success{video=\"Kathirmani Bill Counter\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "D"
        }
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Find Parse Success \u2014 Over Time",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "marlin-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 20,
            "drawStyle": "bars"
          }
        }
      },
      "targets": [
        {
          "expr": "kathirmani_find_parse_success{video=\"Kathirmani Bill Counter\"}",
          "legendFormat": "{{query}}"
        }
      ]
    }
  ]
}