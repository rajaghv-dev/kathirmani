{
  "title": "Marlin-2B — Application / Pipeline",
  "uid": "marlin-pipeline",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["marlin", "pipeline", "events", "surveillance"],
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Videos Processed",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "colorMode": "background", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "blue" }] } } },
      "targets": [{ "expr": "sum(marlin_videos_processed_total{status=\"success\"}) or vector(0)", "legendFormat": "Done" }]
    },
    {
      "id": 2, "type": "stat", "title": "Total Events Detected",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }] } } },
      "targets": [{ "expr": "sum(marlin_events_detected_total) or vector(0)", "legendFormat": "Events" }]
    },
    {
      "id": 3, "type": "stat", "title": "Find Queries Resolved",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "purple" }] } } },
      "targets": [{ "expr": "count(marlin_find_parse_success == 1) or vector(0)", "legendFormat": "Resolved" }]
    },
    {
      "id": 4, "type": "stat", "title": "Errors",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "red" }] } } },
      "targets": [{ "expr": "sum(marlin_videos_processed_total{status=\"error\"}) or vector(0)", "legendFormat": "Errors" }]
    },
    {
      "id": 5, "type": "stat", "title": "Find Parse Success Rate",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["mean"] } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 0.6, "color": "yellow" }, { "value": 0.85, "color": "green" }] } } },
      "targets": [{ "expr": "avg(marlin_find_parse_success) or vector(0)", "legendFormat": "Parse OK" }]
    },
    {
      "id": 6, "type": "stat", "title": "Remaining / Queued",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "blue" }] } } },
      "targets": [{ "expr": "5 - sum(marlin_videos_processed_total) or vector(5)", "legendFormat": "Remaining" }]
    },
    {
      "id": 10, "type": "bargauge", "title": "Events Detected per Camera",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] }, "showUnfilled": true },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "continuous-GrYlRd" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }] } } },
      "targets": [{ "expr": "marlin_events_detected_total", "legendFormat": "{{video}}" }]
    },
    {
      "id": 11, "type": "timeseries", "title": "Videos Processed Over Time",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "drawStyle": "bars", "fillOpacity": 60 } } },
      "targets": [
        { "expr": "increase(marlin_videos_processed_total{status=\"success\"}[5m])", "legendFormat": "Success" },
        { "expr": "increase(marlin_videos_processed_total{status=\"error\"}[5m])", "legendFormat": "Error" }
      ]
    },
    {
      "id": 20, "type": "table", "title": "Find Query Results — All Cameras",
      "description": "Start/end timestamps for each event found by the model in each camera feed",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 12 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "video", "desc": false }] },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value #marlin_find_parse_success" }, "properties": [{ "id": "displayName", "value": "Parsed OK" }, { "id": "unit", "value": "bool" }] },
          { "matcher": { "id": "byName", "options": "Value #marlin_find_span_start_seconds" }, "properties": [{ "id": "displayName", "value": "Start (s)" }] },
          { "matcher": { "id": "byName", "options": "Value #marlin_find_span_end_seconds" }, "properties": [{ "id": "displayName", "value": "End (s)" }] }
        ]
      },
      "targets": [
        { "expr": "marlin_find_span_start_seconds", "legendFormat": "", "instant": true, "refId": "A" },
        { "expr": "marlin_find_span_end_seconds", "legendFormat": "", "instant": true, "refId": "B" },
        { "expr": "marlin_find_parse_success", "legendFormat": "", "instant": true, "refId": "C" }
      ]
    },
    {
      "id": 30, "type": "bargauge", "title": "Find Query — Event Span Duration (seconds found)",
      "description": "Duration = end - start for each resolved query per camera",
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "options": { "orientation": "horizontal", "displayMode": "basic", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "color": { "mode": "continuous-BlYlRd" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "blue" }] } } },
      "targets": [
        { "expr": "marlin_find_span_end_seconds - marlin_find_span_start_seconds", "legendFormat": "{{video}} | {{query}}" }
      ]
    },
    {
      "id": 40, "type": "timeseries", "title": "Find Span Start Times per Camera (event timeline)",
      "description": "When each queried event starts in each video — shows temporal distribution of activity",
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "marlin-metrics" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 0, "pointSize": 8, "drawStyle": "points" } } },
      "targets": [
        { "expr": "marlin_find_span_start_seconds", "legendFormat": "{{video}} – {{query}}" }
      ]
    }
  ]
}
